# ---------- Build outputs ----------
build/
build-*/
out/
dist/
example-builds/
examples/output/
test_project/build/

# ---------- CMake ----------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cmake
# Keep checked-in cross-compile toolchain files (gitignore has no inline comments).
!toolchains/*.cmake

# ---------- Compiled binaries / objects ----------
*.o
*.obj
*.exe
*.out
*.app
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib
*.la
*.lo
*.slo
*.gch
*.pch

# ---------- Editor scratch & backups ----------
*.swp
*.swo
*~
*.bak
*.orig
*.new
*.rej

# ---------- IDE / tooling ----------
.vscode/
.idea/
*.iml
.cache/
compile_commands.json
.clangd/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Temporary / runtime ----------
*.tmp
*.temp
/tmp/ubuilder-*
%TEMP%\ubuilder-*

# ---------- Logs & test outputs ----------
*.log
logs/
test_results.xml
*.gcov
*.gcda
*.gcno
coverage/

# ---------- Package managers / vendored deps ----------
node_modules/
vendor/

# ---------- Python ----------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/

# ---------- Project-specific tooling ----------
.code-review-graph/
.claude/
.sandbox/
